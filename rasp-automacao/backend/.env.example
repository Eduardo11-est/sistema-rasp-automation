# Configuração do Servidor Express
PORT=3000
CORS_ORIGIN=*

# Controle do Banco de Dados: true para Supabase/PostgreSQL, false para Armazenamento em Memória (fallback)
USE_DATABASE=true

# Credenciais do Supabase (Recomendado para Produção/Desenvolvimento)
# Substitua com as chaves do seu projeto no Supabase
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sua-chave-publica-anon-do-supabase

# Credenciais do PostgreSQL Local (Opcional, caso não queira usar Supabase)
# DATABASE_URL=postgres://usuario:senha@host:porta/banco?sslmode=require
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=rasp_automacao
